# ── Supabase（植物雲端資料庫，已接上）──────────────────────────
# 在 Vercel Dashboard > Settings > Environment Variables 設定
# 本機開發複製此檔案為 .env.local 並填入實際值
# Project URL / anon public key 在 Supabase Dashboard > Settings > API 取得
# 建表 SQL 見 supabase/schema.sql（貼到 Supabase SQL Editor 執行一次即可）

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── 系統設定（可選）──────────────────────────────────────────
VITE_APP_NAME=永豐 AI 建築面積計算平台
VITE_APP_VERSION=1.0.0
